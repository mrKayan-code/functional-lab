{
    "tasks": [
        {
            "label": "build lab",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",
                "-Wall",
                "-Wextra",
                "-o",
                "${workspaceFolder}/lab",
                "${workspaceFolder}/*.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
